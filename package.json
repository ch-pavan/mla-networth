{
  "name": "netaworth-india",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:pages": "node scripts/build-github-pages.mjs",
    "build:vercel": "node scripts/build-vercel.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test",
    "db:generate": "drizzle-kit generate",
    "data:import": "node scripts/import-affidavits.mjs",
    "data:history": "node scripts/fetch-recontest-history.mjs",
    "data:winners": "node scripts/fetch-winner-archive.mjs",
    "data:candidates": "node scripts/fetch-candidate-archive.mjs",
    "data:loksabha": "node scripts/fetch-candidate-archive.mjs --chamber=lok_sabha && node scripts/fetch-winner-archive.mjs --chamber=lok_sabha && node scripts/build-lok-sabha-sitting-mps.mjs",
    "data:loksabha:quick": "node scripts/fetch-winner-archive.mjs --chamber=lok_sabha --summary-money && node scripts/build-lok-sabha-sitting-mps.mjs",
    "data:loksabha:mps": "node scripts/build-lok-sabha-sitting-mps.mjs",
    "data:rajyasabha": ".venv-adr/bin/python scripts/extract-adr-rajya-sabha.py work/adr-pdfs/sitting-rajya-sabha-march-2026.pdf public/data/rajya-sabha-sitting-mps.json",
    "data:match-geo": "node scripts/match-constituencies.mjs",
    "data:match-pc-geo": "node scripts/match-pc-constituencies.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-scale": "^4.0.9",
    "@types/geojson": "^7946.0.16",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
